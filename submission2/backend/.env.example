# Copy this file to .env and fill in your values

# Required: Your Google Gemini API key
# Get one at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Database URL (defaults to SQLite for zero-config local dev)
# For PostgreSQL: postgresql://user:password@localhost:5432/quickmove
DATABASE_URL=sqlite:///./quickmove.db

# Optional: n8n webhook URL for broker notification automation
# Set up your n8n instance and update this URL
N8N_WEBHOOK_URL=http://localhost:5678/webhook/broker-assignment

# Optional: Set to "true" to use mock AI responses (no API key needed)
DEMO_MODE=false

# Email notification (Gmail SMTP — no n8n needed)
# Step 1: Enable 2-Step Verification at myaccount.google.com/security
# Step 2: Go to myaccount.google.com/apppasswords
# Step 3: Create an App Password (Mail / Other) — you get a 16-char code
SMTP_USER=yourname@gmail.com
SMTP_PASSWORD=abcd efgh ijkl mnop
# SMTP_HOST and SMTP_PORT default to Gmail (smtp.gmail.com:587) — no need to change
